# =============================================================================
# Relaticle — Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in every value marked <CHANGE_ME>.
# Generate APP_KEY once with:  docker run --rm relaticle php artisan key:generate --show
# Never regenerate APP_KEY on an existing database — it will break encrypted data.
# =============================================================================

# -----------------------------------------------------------------------------
# Docker image
# Override IMAGE_NAME to use a custom-built or private-registry image.
# Default: ghcr.io/relaticle/relaticle:latest
# -----------------------------------------------------------------------------
IMAGE_NAME=ghcr.io/boroborovski/erp-crm:latest

# Direct port the app container listens on (used when the nginx profile is NOT active).
# Set to 80 to serve HTTP directly, or leave as 8080 and put your own proxy in front.
# When using the nginx profile (docker compose --profile nginx up), nginx handles
# ports 80 and 443 and this value is still exposed but nginx is the public entry point.
APP_PORT=8080

# =============================================================================
# Application
# =============================================================================
APP_NAME="Relaticle"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_LOCALE=en

# Full public URL of the application (include https:// in production).
APP_URL=https://crm.example.com

# Optional: restrict the Filament panel to a specific domain.
# Leave empty to serve on the same domain as APP_URL.
APP_PANEL_DOMAIN=

# =============================================================================
# Logging
# =============================================================================
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# =============================================================================
# Database — PostgreSQL 17
# =============================================================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=relaticle
DB_USERNAME=relaticle
DB_PASSWORD=

# PostgreSQL superuser password (used by the postgres service itself).
POSTGRES_PASSWORD=

# =============================================================================
# Cache / Queue / Session — Redis
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# =============================================================================
# Mail — Outbound SMTP
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# IMAP — Inbound Email Integration (Phase 3)
# Leave IMAP_HOST empty to disable mailbox polling entirely.
# =============================================================================
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_ENCRYPTION=ssl

# =============================================================================
# First-boot: Default workspace user
# These variables are consumed by `artisan relaticle:docker-setup` on the very
# first boot (when no users exist in the database). Subsequent boots skip setup.
# =============================================================================
ADMIN_NAME="Admin User"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
ADMIN_TEAM_NAME="My Team"

# =============================================================================
# First-boot: System administrator panel
# The sysadmin panel is separate from the main CRM panel.
# =============================================================================
SYSADMIN_EMAIL=sysadmin@example.com
SYSADMIN_PASSWORD=

# URL path prefix for the system admin panel.
SYSADMIN_PATH=sysadmin

# =============================================================================
# Storage — File uploads
# Use FILESYSTEM_DISK=local for single-server setups (files stored inside the
# container; mount a named volume so they survive image updates).
# Use FILESYSTEM_DISK=s3 for scalable / multi-replica deployments.
# =============================================================================
FILESYSTEM_DISK=local

# S3-compatible object storage (required when FILESYSTEM_DISK=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=

# =============================================================================
# Branding
# =============================================================================
# Custom logo for the landing page header and footer.
# 1. Place your logo file inside public/brand/ (e.g. public/brand/logo.svg).
#    If using Docker, mount the `brand` named volume to /var/www/html/public/brand
#    so the file persists across image updates.
# 2. Set LANDING_LOGO_CUSTOM_PATH to the public URL path (not filesystem path).
#    Example: /brand/logo.svg
# Leave empty to use the built-in Relaticle logo.
LANDING_LOGO_CUSTOM_PATH=

# Custom hero banner image for the landing page hero section.
# 1. Place your image inside public/brand/ (e.g. public/brand/hero.jpg).
# 2. Set LANDING_HERO_BANNER_IMAGE to the public URL path.
#    Example: /brand/hero.jpg
# Leave empty to show no banner image.
LANDING_HERO_BANNER_IMAGE=

# =============================================================================
# Analytics (optional)
# =============================================================================
# Fathom Analytics site ID. Leave empty to disable analytics.
FATHOM_ANALYTICS_SITE_ID=

# =============================================================================
# Error monitoring (optional)
# =============================================================================
# Sentry DSN for exception tracking. Leave empty to disable Sentry.
SENTRY_LARAVEL_DSN=

# =============================================================================
# OAuth — Social Login
# =============================================================================
# GitHub OAuth App — create at https://github.com/settings/developers
# Set the Authorization callback URL to: {APP_URL}/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth App — create at https://console.cloud.google.com/apis/credentials
# Add {APP_URL}/auth/callback/google as an Authorized redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://crm.example.com/auth/callback/google

# =============================================================================
# Stock alerts (Phase 11)
# When enabled, the `products:notify-low-stock` command runs daily at 08:00
# and logs low-stock products to stdout.
# =============================================================================
STOCK_ALERTS_ENABLED=false
